<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context=".SupervisorMainActivity">


    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginTop="16dp"
        android:text="SellSumm"
        android:textColor="@color/teal"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <TextView
        android:id="@+id/textView4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="143dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="110dp"
        android:text="Welcome back User"
        android:textColor="@color/teal"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/unit_stat_1"
        android:layout_width="146dp"
        android:layout_height="75dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="52dp"
        android:background="@drawable/dasboard_small_stats"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="15px"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView3">

        <TextView
            android:id="@+id/textView8"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sales Figure"
            android:textAlignment="center"
            android:textColor="@color/black" />

        <EditText
            android:id="@+id/editTextNumber3"
            android:layout_width="90dp"
            android:layout_height="30dp"
            android:layout_marginLeft="36px"
            android:backgroundTint="@color/white"
            android:ems="10"
            android:inputType="number"
            android:textColor="@color/white" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/unit_stat_2"
        android:layout_width="146dp"
        android:layout_height="75dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="44dp"
        android:background="@drawable/dasboard_small_stats"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="15px"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView4">

        <TextView
            android:id="@+id/textView6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Target"
            android:textAlignment="center"
            android:textColor="@color/black"
            tools:layout_editor_absoluteX="51dp"
            tools:layout_editor_absoluteY="197dp" />

        <EditText
            android:id="@+id/editTextNumber"
            android:layout_width="90dp"
            android:layout_height="30dp"
            android:layout_marginLeft="36px"
            android:backgroundTint="@color/white"
            android:ems="10"
            android:inputType="number"
            android:textColor="@color/white"
            tools:layout_editor_absoluteX="28dp"
            tools:layout_editor_absoluteY="238dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/unit_stat_3"
        android:layout_width="146dp"
        android:layout_height="75dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="44dp"
        android:background="@drawable/dasboard_small_stats"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="15px"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/unit_stat_2">

        <TextView
            android:id="@+id/textView7"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Units Sold"
            android:textAlignment="center"
            tools:layout_editor_absoluteX="260dp"
            tools:layout_editor_absoluteY="219dp" />

        <EditText
            android:id="@+id/editTextNumber2"
            android:layout_width="90dp"
            android:layout_height="30dp"
            android:layout_marginLeft="36px"
            android:backgroundTint="@color/white"
            android:ems="10"
            android:inputType="number"
            android:textColor="@color/white"
            tools:layout_editor_absoluteX="219dp"
            tools:layout_editor_absoluteY="245dp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/kpiRecycler"
        android:layout_width="411dp"
        android:layout_height="365dp"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/unit_stat_3" />



</androidx.constraintlayout.widget.ConstraintLayout>