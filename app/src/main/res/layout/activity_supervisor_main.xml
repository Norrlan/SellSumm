<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context=".SupervisorMainActivity">


    <TextView
        android:id="@+id/textView4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Welcome back Supervisor"
        android:textColor="@color/teal"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/kpi_cards_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/textView4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="91dp"
            android:gravity="center"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/unit_stat_1"
                android:layout_width="138dp"
                android:layout_height="67dp"
                android:layout_marginStart="28dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="30dp"
                android:background="@drawable/dasboard_small_stats"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="15px">

                <TextView
                    android:id="@+id/text_sales_figure_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sales Figure"
                    android:textAlignment="center"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/text_sales_figure_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="£0"
                    android:textAlignment="center"
                    android:textColor="@color/screen_background"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/unit_stat_2"
                android:layout_width="134dp"
                android:layout_height="66dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="30dp"
                android:background="@drawable/dasboard_small_stats"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="15px">

                <TextView
                    android:id="@+id/text_atv_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ATV"
                    android:textAlignment="center"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/text_atv_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="£0"
                    android:textAlignment="center"
                    android:textColor="@color/screen_background"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="99dp"
            android:gravity="center"
            android:orientation="horizontal">


            <LinearLayout
                android:id="@+id/unit_stat_3"
                android:layout_width="wrap_content"
                android:layout_height="65dp"
                android:layout_marginStart="28dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="36dp"
                android:background="@drawable/dasboard_small_stats"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="15px">

                <TextView
                    android:id="@+id/text_upt_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Units per Transaction"
                    android:textAlignment="center"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/text_upt_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textAlignment="center"
                    android:textColor="@color/screen_background"
                    android:textStyle="bold" />
            </LinearLayout>


            <LinearLayout
                android:id="@+id/unit_stat_4"
                android:layout_width="wrap_content"
                android:layout_height="68dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="36dp"
                android:background="@drawable/dasboard_small_stats"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="15px">

                <TextView
                    android:id="@+id/text_spe_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sales Per Employee"
                    android:textAlignment="center"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/text_spe_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="£0"
                    android:textAlignment="center"
                    android:textColor="@color/screen_background"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>


    <TextView
        android:layout_width="163dp"
        android:layout_height="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="152dp"
        android:layout_marginStart="25dp"
        android:layout_marginBottom="8dp"
        android:text="Revenue Overview"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/salesTabLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/kpi_cards_container"
        app:layout_constraintVertical_bias="0.25" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/salesTabLayout"
        android:layout_width="337dp"
        android:layout_height="30dp"
        android:layout_marginStart="36dp"
        android:layout_marginTop="44dp"
        android:background="#808080"
        android:textAlignment="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/kpi_cards_container"
        app:tabIndicatorColor="@color/teal"
        app:tabSelectedTextColor="@color/teal"
        app:tabTextColor="@color/black" />

    <FrameLayout
        android:id="@+id/store_revenue_graph"
        android:layout_width="407dp"
        android:layout_height="213dp"
        android:layout_marginTop="76dp"
        android:background="@color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/kpi_cards_container">

        <!-- Placeholder for MPAndroidChart -->
        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/salesBarChart"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />


    </FrameLayout>

    <LinearLayout
        android:layout_width="407dp"
        android:layout_height="59dp"
        android:layout_marginStart="1dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="4dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.25"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/store_revenue_graph">

        <!-- Sales Tab enable supervisor to see the sales made by the staff -->
        <!-- Staff member cannot see their sales history-->

        <!-- Tab to manage staff members add or delete users. Can only be done from here. -->

        <LinearLayout
            android:id="@+id/sales_tab"
            android:layout_width="114dp"
            android:layout_height="50dp"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/dasboard_small_stats"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="15px">


            <TextView
                android:id="@+id/text_sales_tab_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sales"
                android:textAlignment="center"
                android:textColor="@color/white" />


        </LinearLayout>

        <LinearLayout
            android:id="@+id/staff_member_tab"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginEnd="28dp"

            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/dasboard_small_stats"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="15px">

            <TextView
                android:id="@+id/staff_member_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage Staff"
                android:textAlignment="center"
                android:textColor="@color/white" />

        </LinearLayout>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
