<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context=".DashboardFragment">

    <TextView
        android:id="@+id/textView4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Welcome back Supervisor"
        android:textColor="@color/teal"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/kpi_cards_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/textView4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ROW 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="91dp"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Sales Figure -->
            <LinearLayout
                android:id="@+id/unit_stat_1"
                android:layout_width="138dp"
                android:layout_height="67dp"
                android:layout_marginStart="28dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="30dp"
                android:background="@drawable/dasboard_small_stats"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="15px">

                <TextView
                    android:id="@+id/text_sales_figure_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sales Figure"
                    android:textAlignment="center"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/text_sales_figure_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="£0"
                    android:textAlignment="center"
                    android:textColor="@color/screen_background"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ATV -->
            <LinearLayout
                android:id="@+id/unit_stat_2"
                android:layout_width="134dp"
                android:layout_height="66dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="30dp"
                android:background="@drawable/dasboard_small_stats"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="15px">

                <TextView
                    android:id="@+id/text_atv_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ATV"
                    android:textAlignment="center"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/text_atv_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="£0"
                    android:textAlignment="center"
                    android:textColor="@color/screen_background"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- ROW 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="99dp"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Units per Transaction -->


            <LinearLayout
                android:id="@+id/unit_stat_3"
                android:layout_width="wrap_content"
                android:layout_height="65dp"
                android:layout_marginStart="28dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="42dp"
                android:background="@drawable/dasboard_small_stats"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="15px">

                <TextView
                    android:id="@+id/text_upt_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Units per Transaction"
                    android:textAlignment="center"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/text_upt_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textAlignment="center"
                    android:textColor="@color/screen_background"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/unit_stat_4"
                android:layout_width="wrap_content"
                android:layout_height="68dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="36dp"
                android:background="@drawable/dasboard_small_stats"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="15px">

                <TextView
                    android:id="@+id/text_spe_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sales Per Employee"
                    android:textAlignment="center"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/text_spe_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="£0"
                    android:textAlignment="center"
                    android:textColor="@color/screen_background"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>


    <TextView
        android:id="@+id/revenue_overview_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:text="Overview"
        android:textColor="@color/black"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/kpi_cards_container" />

    <FrameLayout
        android:id="@+id/store_revenue_graph"
        android:layout_width="403dp"
        android:layout_height="185dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="35px"
        android:layout_marginEnd="4dp"
        android:background="@color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/revenue_overview_label">

        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/salesBarChart"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginRight="15px"
            android:padding="8px" />
    </FrameLayout>

    <!-- Sales + Manage Staff Buttons -->
    <LinearLayout
        android:layout_width="407dp"
        android:layout_height="59dp"
        android:layout_marginTop="44dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/store_revenue_graph">

        <!-- Sales Tab -->
        <LinearLayout
            android:id="@+id/sales_tab"
            android:layout_width="114dp"
            android:layout_height="50dp"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:background="@drawable/dasboard_small_stats"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="15px">

            <TextView
                android:id="@+id/text_sales_tab_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Commissions"
                android:textAlignment="center"
                android:textColor="@color/white" />
        </LinearLayout>

        <!-- Manage Staff -->
        <LinearLayout
            android:id="@+id/staff_member_tab"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:background="@drawable/dasboard_small_stats"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="15px">

            <TextView
                android:id="@+id/staff_member_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage Staff"
                android:textAlignment="center"
                android:textColor="@color/white" />
        </LinearLayout>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
